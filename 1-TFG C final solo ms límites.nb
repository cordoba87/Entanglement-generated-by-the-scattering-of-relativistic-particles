     RowBox[{"\"\<--- DESGLOSE DE CONTRIBUCIONES POR CONFIGURACI\
\[CapitalOAcute]N (M = \>\"", ",", "valorMasa", ",", "\"\<) ---\>\""}], "]"}],
     ";"}], "\n", 
   RowBox[{
