     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "2"}], ",", 
         RowBox[{"1", "/", "2"}], ",", "\"\<++\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ",", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ",", "\"\<--\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "/", "2"}], ",", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ",", "\"\<+-\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "2"}], ",", "\"\<-+\>\""}], "}"}]}], "}"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"cabecera", "=", 
     RowBox[{"{", 
      RowBox[{"\"\<h3 h4\>\"", ",", "\"\<S3\>\"", ",", "\"\<S4\>\"", 
       ",", "\"\<T3\>\"", ",", "\"\<T4\>\"", ",", "\"\<U3\>\"", 
       ",", "\"\<U4\>\"", ",", "\"\<Total iM\>\""}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"filasTabla", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"h3", "=", 
            RowBox[{"c", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ",", 
           RowBox[{"h4", "=", 
            RowBox[{"c", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ",", 
           RowBox[{"label", "=", 
            RowBox[{"c", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}], ",", 
         RowBox[{
          RowBox[{"bloques", "=", 
           RowBox[{"calcularBloques", "[", 
            RowBox[{"l1", ",", "l2", ",", "h3", ",", "h4"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"total", "=", 
           RowBox[{"Total", "[", "bloques", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "label", "}"}], ",", "bloques", ",", 
            RowBox[{"{", "total", "}"}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "configSalida"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Resultados", " ", "y", " ", "Concurrencia"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"MRR", ",", "MLL", ",", "MRL", ",", "MLR"}], "}"}], "=", 
     RowBox[{"filasTabla", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"NormN", "=", 
     RowBox[{"procesar", "[", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", "MRR", "]"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"Abs", "[", "MLL", "]"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"Abs", "[", "MRL", "]"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"Abs", "[", "MLR", "]"}], "^", "2"}]}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"CRR", ",", "CLL", ",", "CRL", ",", "CLR"}], "}"}], "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"MRR", ",", "MLL", ",", "MRL", ",", "MLR"}], "}"}], "/", 
      "NormN"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Delta", "=", 
     RowBox[{"procesar", "[", 
      RowBox[{"2", "*", 
       RowBox[{"Abs", "[", 
        RowBox[{
         RowBox[{"CRR", "*", "CLL"}], "-", 
         RowBox[{"CRL", "*", "CLR"}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Sustituci\[OAcute]n", " ", "de", " ", "theta"}], "=", 
     RowBox[{
      RowBox[{"Pi", "/", "2"}], " ", "en", " ", "Delta"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"deltaPiMedios", "=", 
     RowBox[{"procesar", "[", 
      RowBox[{"Delta", "/.", " ", 
       RowBox[{"th", "->", 
        RowBox[{"Pi", "/", "2"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Delta (th = Pi/2): \>\"", ",", "deltaPiMedios"}], "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"limitemasa0", "=", 
    RowBox[{"Limit", "[", 
     RowBox[{"Delta", ",", " ", 
      RowBox[{"valorMasa", "->", "0"}]}], "]"}]}], "\n", 
