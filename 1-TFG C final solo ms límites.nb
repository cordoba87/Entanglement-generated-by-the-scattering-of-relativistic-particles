          RowBox[{"{", 
           RowBox[{
            RowBox[{"Lighter", "[", 
             RowBox[{"Gray", ",", "0.9"}], "]"}], ",", "None"}], "}"}]}], 
         "}"}]}]}], "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
