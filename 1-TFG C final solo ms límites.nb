Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"2", "+", 
        SuperscriptBox["y", "2"]}], ")"}], "2"], "-", 
     RowBox[{"4", " ", 
      SuperscriptBox[
       RowBox[{"Cos", "[", "th", "]"}], "2"]}]}], ")"}], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", "th", "]"}], "2"]}], 
  RowBox[{"3", "+", 
   RowBox[{"4", " ", 
    SuperscriptBox["y", "2"]}], "+", 
   RowBox[{"3", " ", 
    SuperscriptBox["y", "4"]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "4"}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["y", "2"]}], "+", 
      SuperscriptBox["y", "4"]}], ")"}], " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "th"}], "]"}]}], "+", 
   RowBox[{"Cos", "[", 
    RowBox[{"4", " ", "th"}], "]"}]}]]], "Output",
 CellChangeTimes->{3.9859539957463703`*^9, 3.985954032163719*^9, 
  3.9859542106958485`*^9, 3.9862911860755787`*^9, 3.9862927312791653`*^9},
 CellLabel->"Out[71]=",ExpressionUUID->"1b34ba40-184b-1249-9fca-c22a95249800"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Delta(y)= \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"2", "+", 
          SuperscriptBox["y", "2"]}], ")"}], "2"], "-", 
       RowBox[{"4", " ", 
        SuperscriptBox[
         RowBox[{"Cos", "[", "th", "]"}], "2"]}]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "th", "]"}], "2"]}], 
    RowBox[{"3", "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["y", "2"]}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["y", "4"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "4"}], "-", 
        RowBox[{"4", " ", 
         SuperscriptBox["y", "2"]}], "+", 
        SuperscriptBox["y", "4"]}], ")"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "th"}], "]"}]}], "+", 
     RowBox[{"Cos", "[", 
      RowBox[{"4", " ", "th"}], "]"}]}]]}],
  SequenceForm[
  "Delta(y)= ", 
   2 ((2 + $CellContext`y^2)^2 - 4 
    Cos[$CellContext`th]^2) (3 + 4 $CellContext`y^2 + 
     3 $CellContext`y^4 + (-4 - 4 $CellContext`y^2 + $CellContext`y^4) 
      Cos[2 $CellContext`th] + Cos[4 $CellContext`th])^(-1) 
   Sin[$CellContext`th]^2],
  Editable->False]], "Print",
 CellChangeTimes->{3.985953995749359*^9, 3.985954032165245*^9, 
