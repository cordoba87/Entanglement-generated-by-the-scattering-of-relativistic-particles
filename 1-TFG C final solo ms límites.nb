Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"AHORA", " ", "HAGO", " ", "EL", " ", "TAYLOR"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "1.", " ", "Desarrollo", " ", "en", " ", "serie", " ", "de", " ", 
     "Taylor", " ", "alrededor", " ", "de", " ", "x"}], "=", 
    RowBox[{"0", " ", "hasta", " ", "orden", " ", "4"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"serieDelta", "=", 
     RowBox[{"Series", "[", 
      RowBox[{"Deltaxsimplify", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Truncamiento", " ", "del", " ", "t\[EAcute]rmino", " ", "de", 
     " ", "error", " ", 
     RowBox[{
      RowBox[{"O", "[", "x", "]"}], "^", "5"}], " ", "para", " ", "obtener", " ",
      "una", " ", "expresi\[OAcute]n", " ", "algebraica"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"serieNormal", "=", 
     RowBox[{"Normal", "[", "serieDelta", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Simplificaci\[OAcute]n", " ", "rigurosa", " ", "asumiendo", " ",
      "\[AAcute]ngulos", " ", "reales"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"serieSimplificada", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"serieNormal", ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{"Element", "[", 
          RowBox[{"th", ",", "Reals"}], "]"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Visualizaci\[OAcute]n", " ", "del", " ", "resultado", " ", 
     "ordenado", " ", "por", " ", "potencias", " ", "de", " ", "x"}], "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Desarrollo de Taylor de \[CapitalDelta](x, \[Theta]) \
en x=0:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Collect", "[", 
      RowBox[{"serieSimplificada", ",", "x", ",", "FullSimplify"}], "]"}], 
     "]"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.985952659411955*^9, 3.9859526713375206`*^9}, {
   3.985952702825802*^9, 3.985952702961952*^9}, {3.985952775844801*^9, 
