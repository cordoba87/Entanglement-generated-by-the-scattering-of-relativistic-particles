Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Concurrencia = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"2", " ", 
     SqrtBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SuperscriptBox["en", "2"]}], "+", 
         SuperscriptBox["m", "2"], "-", 
         RowBox[{"2", " ", 
          SuperscriptBox["en", "2"], " ", 
          RowBox[{"Cos", "[", "th", "]"}]}]}], ")"}], "2"]], " ", 
