Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"VISUALIZACI\[CapitalOAcute]N", " ", "CON", " ", "Y"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"asuncionesAmpliadas", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"en", ">", "0"}], ",", 
       RowBox[{"Element", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"y", ",", "th"}], "}"}], ",", "Reals"}], "]"}]}], "}"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Deltay", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"Delta", "/.", " ", 
       RowBox[{"{", 
        RowBox[{"m", "->", 
         RowBox[{"en", "*", "y"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"Deltaysimplify", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"Deltay", ",", 
      RowBox[{"Assumptions", "->", "asuncionesAmpliadas"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Delta(y)= \>\"", ",", "Deltaysimplify"}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.98595327646587*^9, 3.9859533024923706`*^9}, 
