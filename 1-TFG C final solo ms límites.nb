         SuperscriptBox["m", "2"], "+", 
         RowBox[{"2", " ", 
          SuperscriptBox["en", "2"], " ", 
          RowBox[{"Cos", "[", "th", "]"}]}]}], ")"}], "2"]], " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "th", "]"}], "2"]}], 
    RowBox[{
     RowBox[{"3", " ", 
      SuperscriptBox["en", "4"]}], "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["en", "2"], " ", 
      SuperscriptBox["m", "2"]}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["m", "4"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "4"}], " ", 
         SuperscriptBox["en", "4"]}], "-", 
        RowBox[{"4", " ", 
         SuperscriptBox["en", "2"], " ", 
         SuperscriptBox["m", "2"]}], "+", 
        SuperscriptBox["m", "4"]}], ")"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "th"}], "]"}]}], "+", 
     RowBox[{
      SuperscriptBox["en", "4"], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"4", " ", "th"}], "]"}]}]}]]}],
  SequenceForm[
  "Concurrencia = ", 
   2 ((2 $CellContext`en^2 + $CellContext`m^2 - 2 $CellContext`en^2 
      Cos[$CellContext`th])^2)^
    Rational[1, 2] ((2 $CellContext`en^2 + $CellContext`m^2 + 
      2 $CellContext`en^2 Cos[$CellContext`th])^2)^
    Rational[1, 2] (3 $CellContext`en^4 + 
     4 $CellContext`en^2 $CellContext`m^2 + 
     3 $CellContext`m^4 + ((-4) $CellContext`en^4 - 
       4 $CellContext`en^2 $CellContext`m^2 + $CellContext`m^4) 
      Cos[2 $CellContext`th] + $CellContext`en^4 Cos[4 $CellContext`th])^(-1) 
   Sin[$CellContext`th]^2],
  Editable->False]], "Print",
