 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "6.", " ", "Ensamblaje", " ", "de", " ", "la", " ", "norma", " ", "y", " ",
     "la", " ", "Concurrencia", " ", "cruda"}], "*)"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"NormN2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", "MRR", "]"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"Abs", "[", "MLL", "]"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"Abs", "[", "MRL", "]"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"Abs", "[", "MLR", "]"}], "^", "2"}]}], ",", "asunciones"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TerminoCruzado", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"MRR", "*", "MLL"}], "-", 
          RowBox[{"MRL", "*", "MLR"}]}], "]"}], "^", "2"}], ",", 
       "asunciones"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DeltaTOT", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"2", "*", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"TerminoCruzado", "/", 
          RowBox[{"NormN2", "^", "2"}]}], "]"}]}], ",", "asunciones"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Normalizaci\[OAcute]n = \>\"", ",", "NormN2"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
