Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "4.", " ", "Generaci\[OAcute]n", " ", "estructural", " ", 
    "param\[EAcute]trica", " ", "de", " ", "los", " ", "diagramas", " ", "de",
     " ", "Feynman"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"calcularBloques", "[", 
      RowBox[{"h1_", ",", "h2_", ",", "h3_", ",", "h4_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "s3l", ",", "s4l", ",", "t3l", ",", "t4l", ",", "u3l", ",", "u4l", ",",
          "listaAmplitudes"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"s3l", "=", 
         RowBox[{
          RowBox[{"g", "^", "2"}], "*", 
          RowBox[{"parRound", "[", 
           RowBox[{
            RowBox[{"xAlphaUp", "[", 
             RowBox[{"h1", ",", "th1", ",", "ph1"}], "]"}], ",", 
            RowBox[{"xAlphaDown", "[", 
             RowBox[{"h2", ",", "th2", ",", "ph2"}], "]"}]}], "]"}], "*", 
          RowBox[{"parSquare", "[", 
           RowBox[{
            RowBox[{"xDaggerAlphaDown", "[", 
             RowBox[{"h3", ",", "th3", ",", "ph3"}], "]"}], ",", 
            RowBox[{"xDaggerAlphaUp", "[", 
             RowBox[{"h4", ",", "th4", ",", "ph4"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"s4l", "=", 
         RowBox[{
          RowBox[{"g", "^", "2"}], "*", 
          RowBox[{"parSquare", "[", 
           RowBox[{
            RowBox[{"yDaggerAlphaDown", "[", 
             RowBox[{"h1", ",", "th1", ",", "ph1"}], "]"}], ",", 
            RowBox[{"yDaggerAlphaUp", "[", 
             RowBox[{"h2", ",", "th2", ",", "ph2"}], "]"}]}], "]"}], "*", 
          RowBox[{"parRound", "[", 
           RowBox[{
            RowBox[{"yAlphaUp", "[", 
             RowBox[{"h3", ",", "th3", ",", "ph3"}], "]"}], ",", 
            RowBox[{"yAlphaDown", "[", 
             RowBox[{"h4", ",", "th4", ",", "ph4"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"t3l", "=", 
         RowBox[{
          RowBox[{"g", "^", "2"}], "*", 
          RowBox[{"parSquare", "[", 
           RowBox[{
            RowBox[{"xDaggerAlphaDown", "[", 
             RowBox[{"h3", ",", "th3", ",", "ph3"}], "]"}], ",", 
            RowBox[{"yDaggerAlphaUp", "[", 
             RowBox[{"h1", ",", "th1", ",", "ph1"}], "]"}]}], "]"}], "*", 
          RowBox[{"parRound", "[", 
           RowBox[{
            RowBox[{"yAlphaUp", "[", 
             RowBox[{"h4", ",", "th4", ",", "ph4"}], "]"}], ",", 
            RowBox[{"xAlphaDown", "[", 
             RowBox[{"h2", ",", "th2", ",", "ph2"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"t4l", "=", 
         RowBox[{
          RowBox[{"g", "^", "2"}], "*", 
          RowBox[{"parRound", "[", 
           RowBox[{
            RowBox[{"yAlphaUp", "[", 
             RowBox[{"h3", ",", "th3", ",", "ph3"}], "]"}], ",", 
            RowBox[{"xAlphaDown", "[", 
             RowBox[{"h1", ",", "th1", ",", "ph1"}], "]"}]}], "]"}], "*", 
          RowBox[{"parSquare", "[", 
           RowBox[{
            RowBox[{"xDaggerAlphaDown", "[", 
             RowBox[{"h4", ",", "th4", ",", "ph4"}], "]"}], ",", 
            RowBox[{"yDaggerAlphaUp", "[", 
             RowBox[{"h2", ",", "th2", ",", "ph2"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"u3l", "=", 
         RowBox[{
          RowBox[{"g", "^", "2"}], "*", 
          RowBox[{"parSquare", "[", 
           RowBox[{
            RowBox[{"xDaggerAlphaDown", "[", 
             RowBox[{"h4", ",", "th4", ",", "ph4"}], "]"}], ",", 
            RowBox[{"yDaggerAlphaUp", "[", 
             RowBox[{"h1", ",", "th1", ",", "ph1"}], "]"}]}], "]"}], "*", 
          RowBox[{"parRound", "[", 
           RowBox[{
            RowBox[{"yAlphaUp", "[", 
             RowBox[{"h3", ",", "th3", ",", "ph3"}], "]"}], ",", 
            RowBox[{"xAlphaDown", "[", 
             RowBox[{"h2", ",", "th2", ",", "ph2"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"u4l", "=", 
         RowBox[{
          RowBox[{"g", "^", "2"}], "*", 
          RowBox[{"parRound", "[", 
           RowBox[{
            RowBox[{"yAlphaUp", "[", 
             RowBox[{"h4", ",", "th4", ",", "ph4"}], "]"}], ",", 
            RowBox[{"xAlphaDown", "[", 
             RowBox[{"h1", ",", "th1", ",", "ph1"}], "]"}]}], "]"}], "*", 
          RowBox[{"parSquare", "[", 
           RowBox[{
            RowBox[{"xDaggerAlphaDown", "[", 
             RowBox[{"h3", ",", "th3", ",", "ph3"}], "]"}], ",", 
            RowBox[{"yDaggerAlphaUp", "[", 
             RowBox[{"h2", ",", "th2", ",", "ph2"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Ensamblaje", " ", "con", " ", "los", " ", "propagadores", " ", 
          "escalares", " ", "masivos"}], "*)"}], 
        RowBox[{"listaAmplitudes", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"I", "/", 
              RowBox[{"(", 
               RowBox[{"varS", "-", 
                RowBox[{"ms", "^", "2"}]}], ")"}]}], ")"}], "*", 
            RowBox[{"(", 
             RowBox[{"s3l", "+", "s4l"}], ")"}]}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "I"}], "/", 
              RowBox[{"(", 
               RowBox[{"varT", "-", 
                RowBox[{"ms", "^", "2"}]}], ")"}]}], ")"}], "*", 
            RowBox[{"(", 
             RowBox[{"t3l", "+", "t4l"}], ")"}]}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"I", "/", 
              RowBox[{"(", 
               RowBox[{"varU", "-", 
                RowBox[{"ms", "^", "2"}]}], ")"}]}], ")"}], "*", 
            RowBox[{"(", 
             RowBox[{"u3l", "+", "u4l"}], ")"}]}]}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Se", " ", "eval\[UAcute]a", " ", "la", " ", "cinem\[AAcute]tica", " ",
           "elegida", " ", "y", " ", "se", " ", "extrae", " ", "la", " ", 
          "amplitud", " ", "total", " ", "del", " ", "proceso"}], "*)"}], 
        RowBox[{"Total", "[", 
         RowBox[{"listaAmplitudes", "/.", " ", "reglasCinematica"}], 
         "]"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Celda 4 ejecutada: Amplitudes param\[EAcute]tricas \
para los 6 diagramas computadas y evaluadas en el CM.\>\"", "]"}], 
    ";"}]}]}]], "Input",
