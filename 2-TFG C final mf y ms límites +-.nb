Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Para", " ", "masa", " ", "escalar", " ", "igual", " ", "a", " ", "la", " ",
     "energ\[IAcute]a"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"deltamf2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"DeltaTOTP", " ", "/.", 
        RowBox[{"{", 
         RowBox[{"ms", "->", "p"}], "}"}]}], ",", "asunciones2"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"asuncionesAmpliadasvr", "=", 
     RowBox[{"{", 
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "th"}], "}"}], ",", "Reals"}], "]"}], "}"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"deltamfx2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"deltamf2", "/.", " ", 
       RowBox[{"{", 
        RowBox[{"p", "->", 
         RowBox[{"mf", "*", "x"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"deltamfxsimplify2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"deltamfx2", ",", 
       RowBox[{"Assumptions", "->", "asuncionesAmpliadasvr"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Delta(x) mf= \>\"", ",", "deltamfxsimplify2"}], 
    "]"}]}]}]], "Input",
