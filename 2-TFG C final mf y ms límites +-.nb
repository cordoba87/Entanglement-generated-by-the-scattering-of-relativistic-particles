Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Delta(x) mf= \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"2", " ", 
     SuperscriptBox["x", "2"], " ", 
     RowBox[{"Abs", "[", 
      RowBox[{"2", "-", 
       RowBox[{"7", " ", 
        SuperscriptBox["x", "2"]}], "+", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["x", "2"]}], ")"}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"2", " ", "th"}], "]"}]}]}], "]"}], " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "th", "]"}], "2"]}], 
    RowBox[{"Abs", "[", 
     RowBox[{"8", "-", 
      RowBox[{"9", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"10", " ", 
       SuperscriptBox["x", "4"]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"8", "-", 
         RowBox[{"8", " ", 
          SuperscriptBox["x", "2"]}], "-", 
         RowBox[{"7", " ", 
          SuperscriptBox["x", "4"]}]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "th"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["x", "4"]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"4", " ", "th"}], "]"}]}]}], "]"}]]}],
  SequenceForm[
  "Delta(x) mf= ", 2 $CellContext`x^2 
   Abs[2 - 7 $CellContext`x^2 + 
     2 (1 + $CellContext`x^2) Cos[2 $CellContext`th]] 
   Abs[8 - 9 $CellContext`x^2 + 
      10 $CellContext`x^4 + (8 - 8 $CellContext`x^2 - 7 $CellContext`x^4) 
       Cos[2 $CellContext`th] + ($CellContext`x^2 + $CellContext`x^4) 
       Cos[4 $CellContext`th]]^(-1) Sin[$CellContext`th]^2],
  Editable->False]], "Print",
 CellChangeTimes->{3.986102231853279*^9, 3.9861259409322586`*^9, 
