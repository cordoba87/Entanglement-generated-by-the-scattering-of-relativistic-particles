Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Delta(y)= \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{"2", "+", 
       RowBox[{"2", " ", 
        SuperscriptBox["y", "2"]}], "+", 
       SuperscriptBox["y", "4"], "-", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["y", "2"]}], ")"}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"2", " ", "th"}], "]"}]}]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "th", "]"}], "2"]}], 
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["y", "2"], "+", 
         SuperscriptBox["y", "4"]}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "4"}], "-", 
         RowBox[{"4", " ", 
          SuperscriptBox["y", "2"]}], "+", 
         SuperscriptBox["y", "4"]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "th"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["y", "2"]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"4", " ", "th"}], "]"}]}]}], "]"}]]}],
  SequenceForm[
  "Delta(y)= ", 2 
   Abs[3 (1 + $CellContext`y^2 + $CellContext`y^4) + (-4 - 
        4 $CellContext`y^2 + $CellContext`y^4) 
       Cos[2 $CellContext`th] + (1 + $CellContext`y^2) 
       Cos[4 $CellContext`th]]^(-1) (2 + 
    2 $CellContext`y^2 + $CellContext`y^4 - 2 (1 + $CellContext`y^2) 
    Cos[2 $CellContext`th]) Sin[$CellContext`th]^2],
  Editable->False]], "Print",
