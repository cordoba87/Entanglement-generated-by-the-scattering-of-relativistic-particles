  RowBox[{"\<\"Delta(x)= \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["x", "4"]}], ")"}]}], "-", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["x", "4"]}], ")"}], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"2", " ", "th"}], "]"}]}]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "th", "]"}], "2"]}], 
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["x", "4"]}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["x", "2"], "+", 
            SuperscriptBox["x", "4"]}], ")"}]}]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "th"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "2"], "+", 
         SuperscriptBox["x", "4"]}], ")"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"4", " ", "th"}], "]"}]}]}], "]"}]]}],
  SequenceForm[
  "Delta(x)= ", 2 
   Abs[3 (1 + $CellContext`x^2 + $CellContext`x^4) + (1 - 
        4 ($CellContext`x^2 + $CellContext`x^4)) 
       Cos[2 $CellContext`th] + ($CellContext`x^2 + $CellContext`x^4) 
