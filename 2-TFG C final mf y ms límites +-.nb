    RowBox[{"Print", "[", 
     RowBox[{"\"\<Concurrencia = \>\"", ",", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"DeltaTOT", ",", "Asuncionespremium"}], "]"}]}], "]"}], 
    ";"}]}]}]], "Input",
