Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"5.", " ", "C\[AAcute]lculo", " ", "de", " ", "Amplitudes", " ", 
    RowBox[{"(", 
     RowBox[{"h1", ",", 
      RowBox[{"h2", " ", "fijos"}]}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"l1", "=", 
     RowBox[{"1", "/", "2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"l2", "=", 
     RowBox[{
      RowBox[{"-", "1"}], "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MRRRaw", "=", 
     RowBox[{"calcularBloques", "[", 
      RowBox[{"l1", ",", "l2", ",", 
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{"1", "/", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MLLRaw", "=", 
     RowBox[{"calcularBloques", "[", 
      RowBox[{"l1", ",", "l2", ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MRLRaw", "=", 
     RowBox[{"calcularBloques", "[", 
      RowBox[{"l1", ",", "l2", ",", 
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MLRRaw", "=", 
     RowBox[{"calcularBloques", "[", 
      RowBox[{"l1", ",", "l2", ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}], ",", 
       RowBox[{"1", "/", "2"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"MRR", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", "MRRRaw", "]"}], ",", "asunciones"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MLL", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", "MLLRaw", "]"}], ",", "asunciones"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MRL", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", "MRLRaw", "]"}], ",", "asunciones"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"MLR", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"ComplexExpand", "[", "MLRRaw", "]"}], ",", "asunciones"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Celda 5 ejecutada: Amplitudes MRR, MLL, MRL, MLR \
generadas raw y simplificadas\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"amplitudevaluada", "=", 
    RowBox[{"MRR", " ", "/.", 
     RowBox[{"{", 
      RowBox[{"mf", "->", "0"}], "}"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Amplitud invariante comprobaci\[OAcute]n = \>\"", ",", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"amplitudevaluada", ",", "asunciones"}], "]"}]}], "]"}], 
    ";"}]}]}]], "Input",
