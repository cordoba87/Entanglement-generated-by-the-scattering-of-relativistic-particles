          RowBox[{"2", " ", "th"}], "]"}]}], "+", 
        RowBox[{
         SuperscriptBox["p", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["ms", "2"], "+", 
           SuperscriptBox["p", "2"]}], ")"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"4", " ", "th"}], "]"}]}]}], ")"}], "2"]]]}],
